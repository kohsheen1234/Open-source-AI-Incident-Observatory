# .env.example — copy to .env and adjust
AGENTWATCH_DATABASE_URL=postgresql+psycopg://agentwatch:agentwatch@localhost:5433/agentwatch
AGENTWATCH_ARTIFACT_DIR=./artifacts
AGENTWATCH_AUTHOR_HASH_SALT=change-me
AGENTWATCH_LOG_LEVEL=INFO
AGENTWATCH_ENVIRONMENT=local
# Live Reddit ingestion is opt-in (leave blank to use replay/HN only):
# AGENTWATCH_REDDIT_CLIENT_ID=
# AGENTWATCH_REDDIT_CLIENT_SECRET=
